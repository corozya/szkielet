# Shared local MCP environment.
# Copy this file to `.env` and keep the result untracked.
# The local MCP wrapper scripts read this file first.

# GitHub MCP token used by host configs.
# Do not commit real credentials here.
GITHUB_MCP_PAT=

# Sentry MCP auth token for `scripts/run-sentry-mcp.sh`.
# Upstream uses SENTRY_ACCESS_TOKEN; the wrapper also accepts SENTRY_AUTH_TOKEN.
SENTRY_ACCESS_TOKEN=

# Optional, required only for Sentry AI tools like `seer`.
# Leave unset if you only need basic MCP tools.
EMBEDDED_AGENT_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Kanboard MCP.
KANBOARD_URL=
KANBOARD_USER=jsonrpc
KANBOARD_TOKEN=
KANBOARD_PROJECT=

# MySQL MCP.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=reczniki
MYSQL_PASSWORD=pass
MYSQL_DATABASE=reczniki
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=10

# Google Analytics MCP and Google Ads MCP.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/application_default_credentials.json
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Facebook MCP.
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Search Console MCP.
GSC_SKIP_OAUTH=true
GSC_CREDENTIALS_PATH=/abs/path/to/service-account.json
GSC_OAUTH_CLIENT_SECRETS_FILE=/abs/path/to/client_secrets.json
