# Copy this file to `.env.analytics` and fill in real values.
# Keep the resulting `.env.analytics` untracked.

# Path to Google Application Default Credentials JSON.
# You can also skip this if `gcloud auth application-default login` created:
# ~/.config/gcloud/application_default_credentials.json
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/application_default_credentials.json

# Google Cloud project used by the Analytics MCP wrapper.
GOOGLE_PROJECT_ID=your-gcp-project-id

# Optional fallback if you prefer to provide it explicitly.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
