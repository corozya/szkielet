{
  "mcpServers": {
    "kanboard": {
      "command": "python3",
      "args": [
        "mcp_servers/kanboard/server.py"
      ],
      "cwd": "."
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PAT_TOKEN}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "filesystem": {
      "command": "bash",
      "args": [
        "scripts/run-filesystem-mcp.sh"
      ],
      "cwd": "."
    },
    "analytics": {
      "command": "bash",
      "args": [
        "scripts/run-google-analytics-mcp.sh"
      ],
      "cwd": "."
    },
    "mysql": {
      "command": "bash",
      "args": [
        "scripts/run-mysql-mcp.sh"
      ],
      "cwd": "."
    },
    "memory": {
      "command": "bash",
      "args": [
        "scripts/run-memory-mcp.sh"
      ],
      "cwd": "."
    },
    "sentry": {
      "command": "bash",
      "args": [
        "scripts/run-sentry-mcp.sh"
      ],
      "cwd": "."
    },
    "gsc": {
      "command": "bash",
      "args": [
        "scripts/run-search-console-mcp.sh"
      ],
      "cwd": "."
    },
    "facebook": {
      "command": "bash",
      "args": [
        "scripts/run-facebook-mcp.sh"
      ],
      "cwd": "."
    },
    "clarity": {
      "command": "bash",
      "args": [
        "scripts/run-clarity-mcp.sh"
      ],
      "cwd": "."
    },
    "google-ads": {
      "command": "bash",
      "args": [
        "scripts/run-google-ads-mcp.sh"
      ],
      "cwd": "."
    }
  }
}
