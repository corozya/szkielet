{
  "version": 1,
  "hooks": {
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/handoff-register-read.sh"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/handoff-register-prompt.sh"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/handoff-stop-check.sh",
        "loop_limit": 3
      },
      {
        "command": ".cursor/hooks/handoff-stop-commit.sh"
      }
    ]
  }
}
