{
  "mcpServers": {
    "kanboard": {
      "command": "python3",
      "args": [
        "mcp_servers/kanboard/server.py"
      ],
      "cwd": "."
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer YOUR_GITHUB_PAT"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "filesystem": {
      "command": "bash",
      "args": [
        "scripts/run-filesystem-mcp.sh"
      ],
      "cwd": "."
    },
    "analytics": {
      "command": "bash",
      "args": [
        "scripts/run-google-analytics-mcp.sh"
      ],
      "cwd": "."
    },
    "mysql": {
      "command": "bash",
      "args": [
        "scripts/run-mysql-mcp.sh"
      ],
      "cwd": "."
    },
    "memory": {
      "command": "bash",
      "args": [
        "scripts/run-memory-mcp.sh"
      ],
      "cwd": "."
    }
  }
}
