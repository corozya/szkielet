# Copy this file to `.env.mysql` and fill in real values.
# Keep the resulting `.env.mysql` untracked.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=

# Optional default database for list/describe/query calls.
MYSQL_DATABASE=

# Optional tuning.
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=10
