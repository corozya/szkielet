# Kanboard JSON-RPC endpoint (ending with /jsonrpc.php)
KANBOARD_URL=http://127.0.0.1:8080/jsonrpc.php

# Kanboard API user (often: jsonrpc)
KANBOARD_USER=jsonrpc

# Kanboard API token (generate in Kanboard UI)
KANBOARD_TOKEN=

# Default project name or id (optional; if empty agents will ask)
KANBOARD_PROJECT=

